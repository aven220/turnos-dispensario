# === BASE DE DATOS GRATUITA (Neon) ===
# 1. Entre a https://neon.tech y cree cuenta gratis (sin tarjeta)
# 2. Cree proyecto: turnos-dispensario
# 3. En Dashboard copie "Connection string" (PostgreSQL)
# 4. Peguela abajo reemplazando la linea DATABASE_URL
#    Debe incluir al final: ?sslmode=require
#
# Ejemplo:
# DATABASE_URL="postgresql://usuario:clave@ep-xxxx.us-east-2.aws.neon.tech/turnos_dispensario?sslmode=require"

DATABASE_URL="PEGUE_AQUI_SU_URL_DE_NEON"

JWT_SECRET="cencoic-turnos-jwt-2026-k8mP2xQ9vL4nR7wZ6sH3fA1bN5jD0eU"
JWT_EXPIRES_IN="12h"

# Un solo puerto para toda la aplicacion (web + API + tiempo real)
PORT=8741
CORS_ORIGIN="http://localhost:8741"

# 127.0.0.1 = solo este equipo | 0.0.0.0 = otros PCs de la red local
HOST=0.0.0.0
