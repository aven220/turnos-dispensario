# =============================================================================
# SERVIDOR DE PRODUCCION — Turnos Dispensario
# IP del servidor: 192.168.20.26
# =============================================================================
#
# Copie este archivo a backend\.env :
#   copy deploy\windows\.env.servidor.example backend\.env
#
# O ejecute: deploy\windows\5-configurar-servidor.bat
#
# CONFLICTOS CON OTROS PROGRAMAS:
# - La aplicacion web usa SOLO el puerto 8741 (poco comun).
# - La base de datos usa PostgreSQL YA instalado en 127.0.0.1:5432
#   (solo localhost, NO abre otro puerto ni otro servicio PostgreSQL).
# - Cree una base DEDICADA "turnos_dispensario" — no afecta otras bases.
# - NO use Docker en este servidor si ya tiene PostgreSQL en el puerto 5432.
#
# =============================================================================

# PostgreSQL nativo (misma instancia que pgAdmin, base dedicada)
DATABASE_URL="postgresql://turnos:TdCencoic2026Disp@127.0.0.1:5432/turnos_dispensario?schema=public"

JWT_SECRET="cencoic-turnos-jwt-2026-k8mP2xQ9vL4nR7wZ6sH3fA1bN5jD0eU"
JWT_EXPIRES_IN="12h"

# Puerto de la aplicacion (web + API + tiempo real). Verifique que 8741 este libre.
PORT=8741

# Escucha en todas las interfaces; los clientes entran por 192.168.20.26:8741
HOST=0.0.0.0

# IP que veran filtro, ventanilla y TV en la red
PUBLIC_SERVER_IP=192.168.20.26

# Acceso desde otros PCs de la red local
CORS_ORIGIN="*"

NODE_ENV=production
