generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  FILTER
  WINDOW
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum TicketStatus {
  GENERADO
  LLAMADO
  ATENDIENDO
  FINALIZADO
  AUSENTE
  CANCELADO
}

enum MediaType {
  VIDEO
  IMAGE
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  passwordHash String     @map("password_hash")
  fullName     String     @map("full_name")
  role         UserRole
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  windowAssignments WindowOperator[]
  ticketsCreated    Ticket[]         @relation("TicketCreatedBy")
  auditLogs         AuditLog[]
  sessions          OperatorSession[]

  @@map("users")
}

model Window {
  id        String   @id @default(cuid())
  name      String
  number    Int      @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  priorities WindowPriority[]
  operators  WindowOperator[]
  tickets    Ticket[]
  sessions   OperatorSession[]
  auditLogs  AuditLog[]

  @@map("windows")
}

model WindowOperator {
  id        String   @id @default(cuid())
  windowId  String   @map("window_id")
  userId    String   @unique @map("user_id")
  isPrimary Boolean  @default(true) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  window Window @relation(fields: [windowId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("window_operators")
}

model Priority {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  sortOrder Int      @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  windows WindowPriority[]
  tickets Ticket[]

  @@map("priorities")
}

model WindowPriority {
  id         String @id @default(cuid())
  windowId   String @map("window_id")
  priorityId String @map("priority_id")

  window   Window   @relation(fields: [windowId], references: [id], onDelete: Cascade)
  priority Priority @relation(fields: [priorityId], references: [id], onDelete: Cascade)

  @@unique([windowId, priorityId])
  @@map("window_priorities")
}

model Ticket {
  id            String       @id @default(cuid())
  uniqueCode    String       @unique @map("unique_code")
  displayCode   String       @map("display_code")
  status        TicketStatus @default(GENERADO)
  priorityId    String       @map("priority_id")
  windowId      String?      @map("window_id")
  createdById   String       @map("created_by_id")
  callCount     Int          @default(0) @map("call_count")
  sequenceNum   Int          @map("sequence_num")
  datePrefix    String       @map("date_prefix")
  calledAt      DateTime?    @map("called_at")
  attendingAt   DateTime?    @map("attending_at")
  finishedAt    DateTime?    @map("finished_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  priority  Priority @relation(fields: [priorityId], references: [id])
  window    Window?  @relation(fields: [windowId], references: [id])
  createdBy User     @relation("TicketCreatedBy", fields: [createdById], references: [id])
  auditLogs AuditLog[]

  @@index([status, priorityId, createdAt])
  @@index([windowId, status])
  @@index([datePrefix, priorityId, sequenceNum])
  @@map("tickets")
}

model OperatorSession {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  windowId     String    @map("window_id")
  startedAt    DateTime  @default(now()) @map("started_at")
  endedAt      DateTime? @map("ended_at")
  ticketsServed Int      @default(0) @map("tickets_served")

  user   User   @relation(fields: [userId], references: [id])
  window Window @relation(fields: [windowId], references: [id])

  @@index([windowId, endedAt])
  @@map("operator_sessions")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String
  details   String?
  windowId  String?  @map("window_id")
  ticketId  String?  @map("ticket_id")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user   User?   @relation(fields: [userId], references: [id])
  window Window? @relation(fields: [windowId], references: [id])
  ticket Ticket? @relation(fields: [ticketId], references: [id])

  @@index([createdAt])
  @@map("audit_logs")
}

model TvMedia {
  id        String    @id @default(cuid())
  title     String
  url       String
  type      MediaType
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("tv_media")
}

model TickerMessage {
  id        String   @id @default(cuid())
  message   String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ticker_messages")
}

model TvSettings {
  id                String @id @default("default")
  upcomingCount     Int    @default(3) @map("upcoming_count")
  windowQueueCount  Int    @default(3) @map("window_queue_count")
  welcomeMessage    String @default("BIENVENIDOS A CENCOIC") @map("welcome_message")

  @@map("tv_settings")
}

model TicketPrintSettings {
  id              String  @id @default("default")
  headerTitle     String  @default("CENCOIC") @map("header_title")
  showHeader      Boolean @default(true) @map("show_header")
  showPriority    Boolean @default(true) @map("show_priority")
  showDisplayCode Boolean @default(true) @map("show_display_code")
  showUniqueCode  Boolean @default(false) @map("show_unique_code")
  showDateTime    Boolean @default(true) @map("show_date_time")
  showFooter      Boolean @default(true) @map("show_footer")
  footerMessage   String  @default("Espere a ser llamado en pantalla") @map("footer_message")

  @@map("ticket_print_settings")
}

model DailyCounter {
  id         String @id @default(cuid())
  datePrefix String @map("date_prefix")
  priorityId String @map("priority_id")
  lastNumber Int    @default(0) @map("last_number")

  @@unique([datePrefix, priorityId])
  @@map("daily_counters")
}
